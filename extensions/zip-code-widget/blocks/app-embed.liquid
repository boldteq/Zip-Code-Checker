{% comment %}
  Zip Code Checker — App Embed Block
  This block controls whether the Zip Code Checker app is active in this theme.
  Enable or disable it from Theme Editor > App Embeds.
  When enabled, it sets window.__zccAppEnabled = true so all widget blocks
  on the page know the app is active and should render.
{% endcomment %}
<script>window.__zccAppEnabled = true;</script>

{% schema %}
{
  "name": "Zip Code Checker",
  "target": "body"
}
{% endschema %}
